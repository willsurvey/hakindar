# =============================================================================
# Screener-specific environment variables
# Copy this to .env.screener and fill in the values
# =============================================================================

# Stockbit credentials (shared with main .env, can be overridden here)
# NOTE: Usually NOT NEEDED if the main Go Engine is running, 
# because the Screener will automatically grab the valid JWT from Redis!
# STOCKBIT_PLAYER_ID=
# STOCKBIT_USERNAME=
# STOCKBIT_PASSWORD=

# Screener mode: A = Market Mover (Stockbit), B = Yahoo Finance (958 saham)
SCREENER_MODE=A

# Maximum stocks in final output
SCREENER_MAX_OUTPUT=5

# Redis connection (auto-set by docker-compose, override for local dev)
# REDIS_HOST=localhost
# REDIS_PORT=6379
